{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.hemato.in" }],
      "destination": "/app.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "lis.hemato.in" }],
      "destination": "/app.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "physio.hemato.in" }],
      "destination": "/app.html"
    },
    {
      "source": "/backend/:path*",
      "destination": "https://smartgumastha-backend-production.up.railway.app/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "api.hemato.in" }],
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,x-auth-token" },
        { "key": "Access-Control-Allow-Credentials", "value": "true" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://hemato.in/:path*",
      "permanent": true,
      "has": [{ "type": "host", "value": "mediwhats.in" }]
    },
    {
      "source": "/:path*",
      "destination": "https://hemato.in/:path*",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.mediwhats.in" }]
    }
  ]
}
