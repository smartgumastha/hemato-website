{
  "rewrites": [
    {
      "source": "/join/phlebotomist",
      "destination": "/phlebo-onboard.html"
    },
    {
      "source": "/join/lab",
      "destination": "/lab-onboard.html"
    },
    {
      "source": "/backend/:path*",
      "destination": "https://smartgumastha-backend-production.up.railway.app/:path*"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.hemato.in" }],
      "destination": "/app.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "lis.hemato.in" }],
      "destination": "/app.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "physio.hemato.in" }],
      "destination": "/app.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "partner.hemato.in" }],
      "destination": "/lab-partner.html"
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "phlebo.hemato.in" }],
      "destination": "/phlebo-app.html"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "destination": "https://hemato.in/:path*",
      "permanent": true,
      "has": [{ "type": "host", "value": "mediwhats.in" }]
    },
    {
      "source": "/:path*",
      "destination": "https://hemato.in/:path*",
      "permanent": true,
      "has": [{ "type": "host", "value": "www.mediwhats.in" }]
    }
  ]
}
